{
  "headers": [
    {
      "source": "/site.webmanifest",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/((icons/.*)|favicon\\.png|apple-touch-icon\\.png)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!icons/|favicon\\.png|apple-touch-icon\\.png|site\\.webmanifest).*)",
      "destination": "/"
    }
  ]
}
